PORT=5003
APP_MODE=dev

# Database
DATABASE_URL=postgresql://user:password@host:5432/database
DB_SCHEMA=vns_saree

# Frontend / CORS
CLIENT_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Auth
JWT_SECRET=change-me
REFRESH_TOKEN_SECRET=change-me
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12
MSG91_AUTHKEY=
# APP_MODE=prod always requires MSG91 OTP. In dev, set true to force real MSG91 verification.
REQUIRE_MSG91_OTP=false

# Uploads
UPLOAD_STORAGE=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email
EMAIL_USER=
EMAIL_PASS=

# Shipping
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=Home
SHIPROCKET_WEBHOOK_SECRET=
PACKAGE_WEIGHT_KG=0.7
RTO_CHARGE_MULTIPLIER=1

# Razorpay webhook signing secret (dashboard > Webhooks > refund.processed / refund.failed)
RAZORPAY_WEBHOOK_SECRET=
